# Enforce LF line endings for all text files in this repository.
# This ensures consistency across Windows, macOS, and Linux contributors.

* text=auto eol=lf

# Explicitly mark common text formats
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.py        text eol=lf
*.sh        text eol=lf

# Binary files — no line-ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.zip       binary
